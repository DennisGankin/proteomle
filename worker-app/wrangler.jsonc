{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "protl-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-21",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "vars": {
    "DAILY_SEED": "proteomle-reviewed-v1",
    "TIMEZONE": "UTC"
  }
}
